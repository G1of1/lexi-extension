{
  "manifest_version": 3,
  "name": "Lexi AI",
  "version": "1.0.0",
  "description": "Lexi is an AI-powered Chrome extension that instantly simplifies complex text into clear, easy-to-understand explanations right where you read.",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs", "identity", "contextMenus"],
  "host_permissions": [
   "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "32": "/icon/PolicyPalIcon.svg"
  },
  "content_scripts" : [{
    "matches": ["<all_urls>"],
    "js": ["content/content.js"],
    "run_at" : "document_idle"
  }],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["<all_urls>"]
    }
  ],
  "oauth2": {
    "client_id": "822422297281-lo47fh20cpjrnvscrh1r0jutdktq655g.apps.googleusercontent.com",
    "scopes": ["openid", "profile", "email"]
  }
}
